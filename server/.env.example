# 서버 설정
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=1h

# Database (docker-compose 환경에서는 자동 주입됨)
DATABASE_URL=postgresql://user:password@localhost:5432/folio

# NAS (docker-compose 환경에서는 컨테이너 내부 경로 /nas로 자동 주입됨, 로컬 개발 시 실제 경로 사용)
NAS_MOUNT_PATH=/Volumes/files/Books
