generator client {
  provider            = "prisma-client"
  output              = "generated"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

model Book {
  id           String    @id @default(uuid())

  // 파일 시스템 정보
  name         String
  type         BookType
  path         String    @unique
  size         Int
  lastSyncAt   DateTime

  // 메타데이터
  title            String
  author           String?
  isbn             String?
  publisher        String?
  publishedAt      DateTime?
  thumbnail        String?
  readingDirection ReadingDirection?

  // 읽기 상태
  lastOpenedAt DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("books")
}

enum BookType {
  PDF
  EPUB
}

enum ReadingDirection {
  LTR
  RTL
  TTB
}
